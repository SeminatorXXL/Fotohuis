<%- companyInfo.gtm_head %>

<!-- Lead developer: Sem van Beek -->

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="index, follow">

<meta name="google-site-verification" content="W7fe-Dge5RDO5ag_tI74e1x1R8v4tAQPgS65_vHu_E0">

<title><%= seo.title %> | <%= companyInfo.name %></title>
<meta name="description" content="<%= seo.description %>">

<link rel="canonical" href="<%= pageUrl %>">
<link rel="alternate" hreflang="nl" href="<%= pageUrl %>">

<meta property="og:title" content="<%= seo.title %> | <%= companyInfo.name %>">
<meta property="og:type" content="website">
<meta property="og:url" content="<%= pageUrl %>">
<meta property="og:description" content="<%= seo.description %>">

<% if (seo.banner) { %>
<meta property="og:image" content="<%= seo.banner %>">
<% } %>

<meta name="theme-color" media="(prefers-color-scheme: light)" content="#d8b866">
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#2a2a2a">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@6.1/dist/fancybox/fancybox.css">

<link rel="stylesheet" href="<%= versionAsset('/css/fonts.css') %>">
<link rel="stylesheet" href="<%= versionAsset('/css/template.css') %>">
<link rel="stylesheet" href="<%= versionAsset('/css/style.css') %>">

<script src="https://kit.fontawesome.com/ee4fcff081.js" crossorigin="anonymous"></script>

<%- companyInfo.cookie %>
