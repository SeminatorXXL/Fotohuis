<!DOCTYPE html>
<html lang="nl">

    <head>
        <%- include('../parts/header') %>
    </head>

<body>
<%- companyInfo.gtm_body %>


    <%- include('../parts/top') %>

    <header>
        <%- include('../parts/navbar') %>
    </header>

    <main>

        <section>
            <figure class="main-logo">
                <img src="/images/<%= companyInfo.logo %>" alt="">
                <figcaption>
                    <h1>
                        <%= page.name %>
                    </h1>
                </figcaption>
            </figure>

            <div class="main-slider swiper">
                <div class="swiper-wrapper">
                    <!-- Loop impressie afbeeldingen -->
                    <figure class="swiper-slide">
                        <img src="" alt="">
                    </figure>
                </div>
            </div>
        </section>

    </main>

    <footer>
        <%- include('../parts/footer') %>
    </footer>

    <%- include('../parts/scripts') %>
    
</body>
</html>
