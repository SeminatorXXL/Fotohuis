<!DOCTYPE html>
<html lang="nl">
<head>
    <%- include('../parts/header') %>
</head>
<body>
<%- companyInfo.gtm_body %>
<%
const contactAddressParts = [
  companyInfo?.address_line_1,
  companyInfo?.address_line_2,
  companyInfo?.postal_code,
  companyInfo?.city,
  companyInfo?.country
].filter(Boolean);
const mapQuery = contactAddressParts.length
  ? contactAddressParts.join(', ')
  : ((companyInfo?.name || 'Fotohuis Venray') + ' Venray');
let openingHoursRows = [];
const isClosedLabel = (value) => /^(gesloten|closed)$/i.test((value || '').toString().trim());
const formatOpeningRange = (row) => {
  const openVal = (row?.open || '').toString().trim();
  const closeVal = (row?.close || '').toString().trim();
  if ((isClosedLabel(openVal) && isClosedLabel(closeVal)) || (!openVal && !closeVal)) return 'Gesloten';
  if (openVal && closeVal) return `${openVal} - ${closeVal}`;
  if (isClosedLabel(openVal) || isClosedLabel(closeVal)) return 'Gesloten';
  return openVal || closeVal || 'Gesloten';
};
try {
  const parsedOpeningHours = JSON.parse(companyInfo?.opening_hours || '[]');
  if (Array.isArray(parsedOpeningHours)) {
    openingHoursRows = parsedOpeningHours
      .map(row => ({
        day: (row?.day || '').toString().trim(),
        open: (row?.open || '').toString().trim(),
        close: (row?.close || '').toString().trim()
      }))
      .filter(row => row.day || row.open || row.close);
  }
} catch (err) {
  openingHoursRows = (companyInfo?.opening_hours || '')
    .toString()
    .split(/\r?\n/)
    .map(line => line.trim())
    .filter(Boolean)
    .map(line => {
      const parts = line.split(':');
      const day = (parts.shift() || '').toString().trim();
      const range = parts.join(':').toString().trim();
      if (!range || /^gesloten$/i.test(range)) return { day, open: '', close: '' };
      const [open, close] = range.split('-').map(v => (v || '').toString().trim());
      return { day, open, close };
    })
    .filter(row => row.day || row.open || row.close);
}
%>

    <header class="site-header">
        <%- include('../parts/top') %>
        <%- include('../parts/navbar') %>
    </header>

    <main>
        <%- include('../parts/banner') %>

        <section class="container-fluid">
            <div class="container">
                <% if (contactStatus === 'ok') { %>
                    <div class="alert alert-success">Bedankt! Je bericht is verzonden.</div>
                <% } %>
                <% if (contactStatus === 'error') { %>
                    <div class="alert alert-danger">Er ging iets mis bij het verzenden. Probeer het opnieuw.</div>
                <% } %>
                <% if (contactStatus === 'invalid') { %>
                    <div class="alert alert-danger">Controleer de verplichte velden en probeer opnieuw.</div>
                <% } %>

                <div class="row g-4">
                    <div class="col-lg-5">
                        <div class="contact-panel">
                            <h2>Contactgegevens</h2>
                            <ul class="contact-list">
                                <% if (companyInfo?.email) { %>
                                    <li><i class="fa-regular fa-envelope"></i><a href="mailto:<%= companyInfo.email %>"><%= companyInfo.email %></a></li>
                                <% } %>
                                <% if (companyInfo?.phone) { %>
                                    <li><i class="fa-solid fa-phone"></i><a href="tel:<%= String(companyInfo.phone).replace(/\s+/g, '') %>"><%= companyInfo.phone %></a></li>
                                <% } %>
                                <% if (companyInfo?.mobile) { %>
                                    <li><i class="fa-solid fa-mobile-screen-button"></i><a href="tel:<%= String(companyInfo.mobile).replace(/\s+/g, '') %>"><%= companyInfo.mobile %></a></li>
                                <% } %>
                                <% if (contactAddressParts.length) { %>
                                    <li><i class="fa-solid fa-location-dot"></i><span><%= [companyInfo.address_line_1, companyInfo.address_line_2].filter(Boolean).join(', ') %><br><%= [companyInfo.postal_code, companyInfo.city].filter(Boolean).join(' ') %><% if (companyInfo.country) { %><br><%= companyInfo.country %><% } %></span></li>
                                <% } %>
                                <% if (openingHoursRows.length) { %>
                                    <li class="contact-hours-item">
                                        <div class="contact-hours">
                                            <span class="contact-hours-title">Openingstijden</span>
                                            <ul class="contact-hours-list">
                                                <% openingHoursRows.forEach((row) => { %>
                                                    <li>
                                                        <span class="day"><%= row.day || 'Onbekend' %></span>
                                                        <span class="time"><%= formatOpeningRange(row) %></span>
                                                    </li>
                                                <% }) %>
                                            </ul>
                                        </div>
                                    </li>
                                <% } %>
                                <% if (!companyInfo?.email && !companyInfo?.phone && !companyInfo?.mobile && !contactAddressParts.length && !openingHoursRows.length) { %>
                                    <li>Nog geen contactgegevens ingesteld.</li>
                                <% } %>
                            </ul>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="contact-panel">
                            <h2>Neem contact op</h2>
                            <form method="post" action="/contact/send" id="contactForm" class="contact-form">
                                <div class="row g-3">
                                    <div class="col-12 contact-honeypot" aria-hidden="true">
                                        <label for="contact_company_website" class="form-label">Website</label>
                                        <input id="contact_company_website" name="company_website" type="text" class="form-control" tabindex="-1" autocomplete="off">
                                    </div>
                                    <div class="col-md-6">
                                        <input id="contact_name" name="name" type="text" class="form-control" placeholder="Naam *" aria-label="Naam" required>
                                    </div>
                                    <div class="col-md-6">
                                        <input id="contact_email" name="email" type="email" class="form-control" placeholder="E-mailadres *" aria-label="E-mailadres" required>
                                    </div>
                                    <div class="col-md-7">
                                        <input id="contact_subject" name="subject" type="text" class="form-control" placeholder="Onderwerp" aria-label="Onderwerp">
                                    </div>
                                    <div class="col-md-5">
                                        <input id="contact_phone" name="phone" type="text" class="form-control" placeholder="Telefoon" aria-label="Telefoon">
                                    </div>
                                    <div class="col-12">
                                        <textarea id="contact_message" name="message" rows="6" class="form-control" placeholder="Bericht *" aria-label="Bericht" required></textarea>
                                    </div>
                                    <div class="col-12">
                                        <input type="hidden" name="recaptcha_token" id="recaptcha_token">
                                        <button type="submit" class="btn btn-primary">Verzenden</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="container-fluid mb-0 p-0">
            <div class="contact-map">
                <iframe src="https://www.google.com/maps?q=<%= encodeURIComponent(mapQuery) %>&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen title="Google Maps locatie van <%= companyInfo?.name || 'Fotohuis Venray' %>"></iframe>
            </div>
        </section>
    </main>

    <footer>
        <%- include('../parts/footer') %>
    </footer>

    <%- include('../parts/scripts') %>
    <script>
        (function () {
            const form = document.getElementById('contactForm');
            const tokenInput = document.getElementById('recaptcha_token');
            const recaptchaKey = '<%= companyInfo?.recaptcha_public_key || '' %>';
            if (!form || !tokenInput || !recaptchaKey) return;

            form.addEventListener('submit', function (event) {
                if (!window.grecaptcha) return;
                if (tokenInput.value) return;

                event.preventDefault();
                grecaptcha.ready(function () {
                    grecaptcha.execute(recaptchaKey, { action: 'contact' }).then(function (token) {
                        tokenInput.value = token;
                        form.submit();
                    });
                });
            });
        })();
    </script>
</body>
</html>
