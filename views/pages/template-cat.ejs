<!DOCTYPE html>
<html lang="nl">

<head>

    <%- include('../parts/header') %>
    
</head>

<body>
<%- companyInfo.gtm_body %>

    <header class="site-header">
        <%- include('../parts/top') %>
        <%- include('../parts/navbar') %>
    </header>
    
    <main>
        <%- include('../parts/banner') %>

        <section class="container-fluid bg-color">
            <div class="container">
                <% if (page.text) { %>
                    <div class="content">
                        <% if (page.title) { %>
                            <h2><%- page.title %></h2>
                        <% } %>
                        <%- page.text %>
                    </div>
                <% } %>
            </div>
        </section>

        <section class="container-fluid">
            <div class="container">
                <h2 class="text-center wow animate__fadeInUp" data-wow-duration="0.7s">Impressies</h2>
                <% if (impressions && impressions.length) { %>
                <div class="impression-masonry">
                    <% impressions.forEach((impression, index) => { %>
                        <a
                            class="impression-masonry-item wow animate__fadeInUp"
                            data-wow-delay="<%= `${Math.min(index * 0.05, 0.3)}s` %>"
                            href="<%= impression.path %>"
                            data-fancybox="category-impressions"
                            data-caption="<%= impression.name || page.name %>"
                            title="<%= impression.name || page.name %>">
                            <img src="<%= impression.path %>" alt="<%= impression.alt || impression.name || page.name %>" loading="lazy">
                            <span class="impression-overlay">
                                <span class="impression-name"><%= impression.name || page.name %></span>
                            </span>
                        </a>
                    <% }) %>
                </div>
                <% } else { %>
                    <p>Er zijn nog geen impressies beschikbaar.</p>
                <% } %>
            </div>  
        </section>

    </main>

    <footer>
        <%- include('../parts/footer') %>
    </footer>

    <%- include('../parts/scripts') %>

</body>
</html>
