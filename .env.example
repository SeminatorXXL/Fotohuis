# Server
PORT=3000
USE_HTTPS=false
BASE_URL=https://www.fotohuisvenray.nl
SESSION_SECRET=vervang-dit-met-een-lange-unieke-geheime-sleutel
TRAEFIK_ACME_EMAIL=info@fotohuisvenray.nl

# SSL for direct Node HTTPS usage only
CERT_KEY_PATH=
CERT_FULLCHAIN_PATH=
SSL_KEY_PATH=
SSL_CERT_PATH=

# SMTP secret encryption
SMTP_SECRET_KEY=vervang-dit-met-een-lange-unieke-geheime-sleutel

# Database
DB_HOST=db
DB_USER=fotohuis
DB_PASSWORD=vervang-dit-met-een-sterk-db-wachtwoord
DB_ROOT_PASSWORD=vervang-dit-met-een-sterk-root-wachtwoord
DB_NAME=fotohuis

# Encryption
BCRYPT_ROUNDS=12

# Uploads
UPLOAD_DIR=public/media

# CSRF
USE_CSRF=false
