<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('parts/header') %>
</head>

<body>
    <main class="d-flex">

        <div class="sidebar">
           <%- include('parts/sidebar', { session: session }) %>
        </div>

        <div class="content container">

            <h1>Dashboard</h1>

            <div class="row">               

                <div class="col-md-4">
                    <a href="https://search.google.com/search-console" target="_blank" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <h5>Google Search Console</h5>
                            <i class="fab fa-google fa-2x"></i>
                        </div>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="https://analytics.google.com" target="_blank" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <h5>Google Analytics</h5>
                            <i class="fab fa-google fa-2x"></i>
                        </div>
                    </a>
                </div>
            </div>

            <div class="separator"></div>

            <div class="row cards-row">

                <div class="col-md-6">
                    <a href="/cms/pages" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-file fa-2x"></i>
                            <h5>Pagina's</h5>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a href="/cms/categories" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-icons fa-2x"></i>
                            <h5>Categorieën</h5>                            
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a href="/cms/impression" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-trophy fa-2x"></i>
                            <h5>Impressie</h5>                            
                        </div>
                    </a>
                </div>

            </div>
            
            <div class="separator"></div>
            
            <div class="row cards-row">

                <div class="col-md-6">
                    <a href="/cms/general" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-building fa-2x"></i>
                            <h5>General Information</h5>                            
                        </div>
                    </a>
                </div>

                 <div class="col-md-6">
                    <a href="/cms/redirects" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-signs-post fa-2x"></i>
                            <h5>redirects</h5>                         
                        </div>
                    </a>
                </div>

                 <div class="col-md-6">
                    <a href="/cms/media" class="text-decoration-none text-dark">
                        <div class="card p-3 text-center h-100">
                            <i class="fas fa-images fa-2x"></i>
                            <h5>Media</h5>                         
                        </div>
                    </a>
                </div>


                <% if (session?.user?.role === 'admin') { %>
                    <div class="col-md-6">
                        <a href="/cms/users" class="text-decoration-none text-dark">
                            <div class="card p-3 text-center h-100">
                                <i class="fas fa-user fa-2x"></i>
                                <h5>Users</h5>                         
                            </div>
                        </a>
                    </div>
                <% } %>
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
