<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <title>Inloggen | Fotohuis Venray</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="<%= versionAsset('/private/style.css') %>">
  <link rel="icon" href="<%= companyInfo?.favicon || '/images/fav/favicon-32x32.png' %>">
</head>
<body class="login-page">
  <div class="login-card">
    <div class="login-card-body">
      <div class="text-center mb-4">
        <img src="/private/images/logo.png" alt="" class="login-logo">
        <h1 class="login-title">Dashboard inloggen</h1>
        <p class="login-subtitle">Beek'n CMS</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger d-flex align-items-center">
          <i class="fa-solid fa-triangle-exclamation me-2"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form class="text-start" method="post" action="/login" novalidate>
        <div class="mb-3">
          <label for="email" class="form-label">E-mail</label>
          <input type="email" class="form-control login-input" id="email" name="email" required>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label">Wachtwoord</label>
          <input type="password" class="form-control login-input" id="password" name="password" required>
        </div>

        <button class="btn login-btn w-100" type="submit">
          <i class="fa-solid fa-right-to-bracket me-2"></i> Inloggen
        </button>
      </form>
    </div>
  </div>
</body>
</html>
