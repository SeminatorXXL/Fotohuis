<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('parts/header') %>
  <title>Account | <%= companyInfo?.name || 'Admin' %></title>
</head>
<body>
<main class="d-flex">
  <div class="sidebar">
    <%- include('parts/sidebar') %>
  </div>

  <div class="content container">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h1 class="mb-0">
        <i class="fa-solid fa-user-shield me-2"></i> Account
      </h1>
      <a href="/cms" class="btn btn-outline-secondary">
        <i class="fa-solid fa-gauge me-1"></i> Dashboard
      </a>
    </div>

    <%- include('parts/flash') %>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger" role="alert">
        <ul class="mb-0">
          <% errors.forEach(e => { %>
            <li><%= e.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title mb-3"><i class="fa-solid fa-key me-2"></i> Change password</h5>
        <form method="post" action="/cms/account/password" autocomplete="off" class="row g-3">
          <div class="col-12 col-md-6">
            <label for="current_password" class="form-label">Current password</label>
            <input type="password" id="current_password" name="current_password" class="form-control form-control-dark" required>
          </div>
          <div class="col-12 col-md-6"></div>

          <div class="col-12 col-md-6">
            <label for="new_password" class="form-label">New password</label>
            <input type="password" id="new_password" name="new_password" class="form-control form-control-dark" minlength="8" required>
            <div class="form-text text-muted">
              At least 8 chars, incl. 1 uppercase, 1 lowercase, and 1 digit.
            </div>
          </div>

          <div class="col-12 col-md-6">
            <label for="confirm_password" class="form-label">Confirm new password</label>
            <input type="password" id="confirm_password" name="confirm_password" class="form-control form-control-dark" required>
          </div>

          <div class="col-12">
            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-floppy-disk me-1"></i> Save new password
            </button>
          </div>
        </form>
      </div>
    </div>

  </div>
</main>
</body>
</html>
