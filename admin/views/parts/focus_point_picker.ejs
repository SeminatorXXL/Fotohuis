<%
const pickerBaseId = `${focusXFieldId}_picker`;
const pickerId = `${pickerBaseId}_surface`;
const previewId = `${pickerBaseId}_preview`;
const markerId = `${pickerBaseId}_marker`;
const resetId = `${pickerBaseId}_reset`;
const initialX = Number.isFinite(Number(focusXValue)) ? Number(focusXValue) : 50;
const initialY = Number.isFinite(Number(focusYValue)) ? Number(focusYValue) : 50;
%>
<style>
  .focus-point-picker {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: repeating-linear-gradient(45deg, #f3f5f7, #f3f5f7 14px, #e9edf1 14px, #e9edf1 28px);
    cursor: crosshair;
  }

  .focus-point-picker img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .focus-point-picker[hidden] {
    display: none !important;
  }

  .focus-point-marker {
    position: absolute;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: rgba(13, 110, 253, 0.95);
    box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.2);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .focus-point-marker::before,
  .focus-point-marker::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    background: #fff;
    transform: translate(-50%, -50%);
  }

  .focus-point-marker::before {
    width: 2px;
    height: 28px;
  }

  .focus-point-marker::after {
    width: 28px;
    height: 2px;
  }
</style>
<div class="col-12">
  <label class="form-label"><%= label || 'Focuspunt banner' %></label>
  <div id="<%= pickerId %>" class="focus-point-picker" role="button" tabindex="0" aria-label="Klik op de preview om het focuspunt voor de banner te kiezen">
    <img id="<%= previewId %>" alt="Preview focuspunt banner">
    <span id="<%= markerId %>" class="focus-point-marker" aria-hidden="true"></span>
  </div>
  <div class="form-text"><%= helpText || 'Klik op de preview om te bepalen welk deel van de banner in beeld moet blijven bij de uitsnede.' %></div>
</div>
<div class="col-md-3">
  <label for="<%= focusXFieldId %>" class="form-label">Focus X (%)</label>
  <input id="<%= focusXFieldId %>" name="<%= focusXFieldName %>" class="form-control" type="number" min="0" max="100" step="0.1" value="<%= initialX %>">
</div>
<div class="col-md-3">
  <label for="<%= focusYFieldId %>" class="form-label">Focus Y (%)</label>
  <input id="<%= focusYFieldId %>" name="<%= focusYFieldName %>" class="form-control" type="number" min="0" max="100" step="0.1" value="<%= initialY %>">
</div>
<div class="col-md-6 d-flex align-items-end">
  <button type="button" class="btn btn-outline-secondary" id="<%= resetId %>">Reset naar midden</button>
</div>
<script>
  (() => {
    const pathInput = document.getElementById('<%= imageFieldId %>');
    const focusXInput = document.getElementById('<%= focusXFieldId %>');
    const focusYInput = document.getElementById('<%= focusYFieldId %>');
    const picker = document.getElementById('<%= pickerId %>');
    const preview = document.getElementById('<%= previewId %>');
    const marker = document.getElementById('<%= markerId %>');
    const resetButton = document.getElementById('<%= resetId %>');

    if (!pathInput || !focusXInput || !focusYInput || !picker || !preview || !marker || !resetButton) {
      return;
    }

    function buildSrc(val, base) {
      if (!val) return '';
      const v = String(val).trim().replace(/\\/g, '/');
      if (/^https?:\/\//i.test(v)) return v;
      if (v.startsWith('/')) return v;
      if (v.startsWith('media/')) return '/' + v;
      if (v.includes('/')) return '/media/' + v.replace(/^\/+/, '');
      return '/media' + (base ? '/' + base : '') + '/' + v;
    }

    function clampPercent(value) {
      const parsed = Number.parseFloat(String(value ?? '').replace(',', '.'));
      if (!Number.isFinite(parsed)) return 50;
      return Math.min(100, Math.max(0, parsed));
    }

    function syncPreviewSource() {
      const src = buildSrc(pathInput.value, (pathInput.dataset.previewBase || '').replace(/^\/|\/$/g, ''));
      const hasImage = Boolean(src);

      picker.hidden = !hasImage;

      if (hasImage) {
        preview.src = src;
      } else {
        preview.removeAttribute('src');
      }
    }

    function syncMarker() {
      const x = clampPercent(focusXInput.value);
      const y = clampPercent(focusYInput.value);

      focusXInput.value = x % 1 === 0 ? String(x) : x.toFixed(1);
      focusYInput.value = y % 1 === 0 ? String(y) : y.toFixed(1);
      marker.style.left = `${x}%`;
      marker.style.top = `${y}%`;
      preview.style.objectPosition = `${x}% ${y}%`;
    }

    function setFocusFromPointer(clientX, clientY) {
      const rect = picker.getBoundingClientRect();
      if (!rect.width || !rect.height) return;

      const x = ((clientX - rect.left) / rect.width) * 100;
      const y = ((clientY - rect.top) / rect.height) * 100;

      focusXInput.value = clampPercent(x).toFixed(1);
      focusYInput.value = clampPercent(y).toFixed(1);
      syncMarker();
    }

    picker.addEventListener('click', (event) => {
      setFocusFromPointer(event.clientX, event.clientY);
    });

    picker.addEventListener('keydown', (event) => {
      const step = event.shiftKey ? 10 : 2;
      let handled = true;
      const currentX = clampPercent(focusXInput.value);
      const currentY = clampPercent(focusYInput.value);

      if (event.key === 'ArrowLeft') focusXInput.value = currentX - step;
      else if (event.key === 'ArrowRight') focusXInput.value = currentX + step;
      else if (event.key === 'ArrowUp') focusYInput.value = currentY - step;
      else if (event.key === 'ArrowDown') focusYInput.value = currentY + step;
      else handled = false;

      if (!handled) return;

      event.preventDefault();
      syncMarker();
    });

    focusXInput.addEventListener('input', syncMarker);
    focusYInput.addEventListener('input', syncMarker);
    pathInput.addEventListener('input', syncPreviewSource);
    pathInput.addEventListener('change', syncPreviewSource);

    resetButton.addEventListener('click', () => {
      focusXInput.value = '50';
      focusYInput.value = '50';
      syncMarker();
    });

    syncPreviewSource();
    syncMarker();
  })();
</script>
