<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- CMS pages should not be indexed -->
<meta name="robots" content="noindex, nofollow" />

<% const faviconHref = companyInfo?.favicon || '/images/fav/favicon-32x32.png'; %>
<link rel="icon" href="<%= faviconHref %>">
<link rel="shortcut icon" href="<%= faviconHref %>">

<title><%= typeof page_title !== 'undefined' ? page_title + ' | ' : '' %> <%= companyInfo.name %></title>

<!-- CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/private/style.css" rel="stylesheet"><!-- your CMS stylesheet -->

<!-- Icons -->
<script src="https://kit.fontawesome.com/ee4fcff081.js" crossorigin="anonymous"></script>
