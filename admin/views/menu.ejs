<!DOCTYPE html>
<html lang="nl">
<head>
  <%- include('parts/header') %>
</head>
<body>
<main class="d-flex">
  <div class="sidebar">
    <%- include('parts/sidebar', { session: session }) %>
  </div>

  <div class="content container">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h1 class="mb-0">Menu</h1>
      <a href="/cms/menu?new=1" class="btn btn-outline-secondary">Nieuw menu-item</a>
    </div>

    <% if (saved) { %>
      <div class="alert alert-success">Menu opgeslagen.</div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach(error => { %>
            <li><%= error.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="row g-3 editor-shell">
      <div class="col-12 col-xxl-3 col-xl-4 col-lg-4">
        <div class="card editor-list">
          <div class="card-body p-0">
            <div class="list-group list-group-flush">
              <% if (menuItems.length) { %>
                <% menuItems.forEach(item => { %>
                  <a href="/cms/menu/<%= item.id %>" class="list-group-item list-group-item-action <%= Number(menuForm.id) === Number(item.id) ? 'active' : '' %>">
                    <div class="d-flex justify-content-between gap-2">
                      <span class="fw-semibold">
                        <%= item.depth === 1 ? '-- ' : '' %><%= item.name %>
                      </span>
                      <small><%= item.display_order %></small>
                    </div>
                    <small class="text-muted"><%= item.path || '#' %></small>
                  </a>
                <% }) %>
              <% } else { %>
                <div class="list-group-item text-muted">Nog geen menu-items.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xxl-9 col-xl-8 col-lg-8">
        <div class="card editor-form">
          <div class="card-body">
            <h2 class="h5 mb-3"><%= editing ? 'Menu-item bewerken' : 'Menu-item toevoegen' %></h2>

            <form method="post" action="<%= editing ? '/cms/menu/update/' + menuForm.id : '/cms/menu/create' %>">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="menu_name" class="form-label">Naam *</label>
                  <input id="menu_name" name="name" class="form-control" required value="<%= menuForm.name || '' %>">
                </div>

                <div class="col-md-6">
                  <label for="menu_title" class="form-label">Titel-attribuut</label>
                  <input id="menu_title" name="title" class="form-control" value="<%= menuForm.title || '' %>">
                </div>

                <div class="col-md-8">
                  <label for="menu_path" class="form-label">URL</label>
                  <input id="menu_path" name="path" class="form-control" placeholder="/over-ons of https://..." value="<%= menuForm.path || '' %>">
                  <div class="form-text">Laat leeg om een dropdown-label zonder eigen link te maken. Dan wordt automatisch <code>#</code> opgeslagen.</div>
                </div>

                <div class="col-md-4">
                  <label for="menu_target" class="form-label">Doelvenster *</label>
                  <select id="menu_target" name="target" class="form-select" required>
                    <option value="_self" <%= menuForm.target === '_self' ? 'selected' : '' %>>Zelfde tab</option>
                    <option value="_blank" <%= menuForm.target === '_blank' ? 'selected' : '' %>>Nieuwe tab</option>
                  </select>
                </div>

                <div class="col-md-4">
                  <label for="menu_sort_order" class="form-label">Positie *</label>
                  <input id="menu_sort_order" name="sort_order" class="form-control" required placeholder="1 of 1.2" value="<%= menuForm.sort_order || '' %>">
                </div>

                <div class="col-md-8">
                  <label class="form-label">Uitleg</label>
                  <div class="border rounded p-3 bg-light text-dark small h-100">
                    Gebruik <strong>1</strong>, <strong>2</strong>, <strong>3</strong> voor hoofdmenu-items.
                    Gebruik <strong>1.1</strong>, <strong>1.2</strong>, <strong>1.3</strong> voor dropdown-items onder menu-item <strong>1</strong>.
                    Alleen een niveau dropdown wordt ondersteund.
                  </div>
                </div>
              </div>

              <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Opslaan</button>
                <% if (editing) { %>
                  <button type="submit" form="deleteMenuForm" class="btn btn-outline-danger" onclick="return confirm('Menu-item verwijderen? Eventuele dropdown-items worden ook verwijderd.');">Verwijderen</button>
                <% } %>
              </div>
            </form>
            <% if (editing) { %>
              <form id="deleteMenuForm" method="post" action="/cms/menu/delete/<%= menuForm.id %>"></form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
