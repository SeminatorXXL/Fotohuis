<!DOCTYPE html>
<html lang="nl">
<head>
  <%- include('parts/header') %>
</head>
<body>
<main class="d-flex">
  <div class="sidebar">
    <%- include('parts/sidebar', { session: session }) %>
  </div>

  <div class="content container">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h1 class="mb-0">Pagina's</h1>
      <a href="/cms/pages?new=1" class="btn btn-outline-secondary">Nieuwe pagina</a>
    </div>

    <% if (saved) { %>
      <div class="alert alert-success">Pagina opgeslagen.</div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach(e => { %>
            <li><%= e.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="row g-3 editor-shell">
      <div class="col-12 col-xxl-2 col-xl-3 col-lg-4">
        <div class="card editor-list">
          <div class="card-body p-0">
            <div class="list-group list-group-flush">
              <% if (pages.length) { %>
                <% pages.forEach(page => { %>
                  <a href="/cms/pages/<%= page.id %>" class="list-group-item list-group-item-action <%= Number(pageForm.id) === Number(page.id) ? 'active' : '' %>">
                    <div class="fw-semibold"><%= page.name %></div>
                    <small class="text-muted"><%= page.alias %> · <%= page.template %></small>
                  </a>
                <% }) %>
              <% } else { %>
                <div class="list-group-item text-muted">Nog geen pagina's.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xxl-10 col-xl-9 col-lg-8">
        <div class="card editor-form">
          <div class="card-body">
            <h2 class="h5 mb-3"><%= editing ? 'Pagina bewerken' : 'Pagina toevoegen' %></h2>
            <form method="post" action="<%= editing ? '/cms/pages/update/' + pageForm.id : '/cms/pages/create' %>">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="name" class="form-label">Naam *</label>
                  <input id="name" name="name" class="form-control" required value="<%= pageForm.name || '' %>">
                </div>
                <div class="col-md-6">
                  <label for="template" class="form-label">Template *</label>
                  <select id="template" name="template" class="form-select" required>
                    <% templates.forEach(template => { %>
                      <option value="<%= template %>" <%= (pageForm.template === template) ? 'selected' : '' %>><%= template %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="page_alias" class="form-label">Alias (URL) *</label>
                  <input id="page_alias" name="alias" class="form-control" required placeholder="bijv. expertise of /" value="<%= pageForm.alias || '' %>">
                </div>
                <div class="col-md-6">
                  <label for="page_title" class="form-label">Google titel</label>
                  <input id="page_title" name="google_title" class="form-control" data-company="<%= companyInfo?.name || '' %>" value="<%= pageForm.google_title || '' %>">
                </div>
                <div class="col-12">
                  <label for="page_description" class="form-label">Meta beschrijving</label>
                  <input id="page_description" name="meta_description" class="form-control" value="<%= pageForm.meta_description || '' %>">
                </div>
                <div class="col-12">
                  <div class="row g-2">
                    <div class="col-md-4">
                      <div class="form-check form-switch">
                        <input type="hidden" name="seo_index" value="0">
                        <input class="form-check-input" type="checkbox" id="seo_index" name="seo_index" value="1" <%= Number(pageForm.seo_index ?? 1) === 1 ? 'checked' : '' %>>
                        <label class="form-check-label" for="seo_index">SEO indexeren</label>
                      </div>
                    </div>
                    <div class="col-md-4">
                      <div class="form-check form-switch">
                        <input type="hidden" name="seo_follow" value="0">
                        <input class="form-check-input" type="checkbox" id="seo_follow" name="seo_follow" value="1" <%= Number(pageForm.seo_follow ?? 1) === 1 ? 'checked' : '' %>>
                        <label class="form-check-label" for="seo_follow">SEO volgen</label>
                      </div>
                    </div>
                    <div class="col-md-4">
                      <div class="form-check form-switch">
                        <input type="hidden" name="seo_sitemap" value="0">
                        <input class="form-check-input" type="checkbox" id="seo_sitemap" name="seo_sitemap" value="1" <%= Number(pageForm.seo_sitemap ?? 1) === 1 ? 'checked' : '' %>>
                        <label class="form-check-label" for="seo_sitemap">In sitemap opnemen</label>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-12">
                  <div class="card seo-meter-panel">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 mb-0">SEO meter</h3>
                        <span id="seo-score-badge" class="badge text-bg-secondary px-3 py-2">SEO-score: 0/100</span>
                      </div>
                      <div class="row g-3">
                        <div class="col-md-4">
                          <label for="focus_keyword" class="form-label">Focuszoekwoord</label>
                          <input id="focus_keyword" type="text" class="form-control" placeholder="bijv. trouwfotografie venray">
                        </div>
                        <div class="col-md-8">
                          <label for="seo_title_computed" class="form-label">Berekende titelpreview</label>
                          <input id="seo_title_computed" type="text" class="form-control" readonly>
                        </div>
                        <div class="col-md-6">
                          <div class="small mb-1" id="title-length">0 tekens</div>
                          <div class="progress"><div id="title-progress" class="progress-bar" style="width:0%"></div></div>
                          <ul id="title-tips" class="small mt-2 mb-0"></ul>
                        </div>
                        <div class="col-md-6">
                          <div class="small mb-1" id="desc-length">0 tekens</div>
                          <div class="progress"><div id="desc-progress" class="progress-bar" style="width:0%"></div></div>
                          <ul id="desc-tips" class="small mt-2 mb-0"></ul>
                        </div>
                        <div class="col-md-4">
                          <div class="small mb-1">Alias bevat zoekwoord</div>
                          <span id="alias-check" class="badge text-bg-secondary">-</span>
                        </div>
                        <div class="col-md-4">
                          <div class="small mb-1">Titel start met zoekwoord</div>
                          <span id="title-begin-check" class="badge text-bg-secondary">-</span>
                        </div>
                        <div class="col-md-4">
                          <div class="small mb-1">Leesbaarheid: <span id="readability-score">0/100</span></div>
                          <div class="progress"><div id="readability-progress" class="progress-bar" style="width:0%"></div></div>
                          <ul id="readability-tips" class="small mt-2 mb-0"></ul>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-6" id="bannerFieldWrap">
                  <%- include('parts/image_field_with_picker', {
                    fieldId: 'banner',
                    fieldName: 'banner',
                    label: 'Banner afbeelding',
                    value: pageForm.banner || '',
                    placeholder: '/media/banners/pagina.jpg'
                  }) %>
                </div>
                <div class="col-md-6">
                  <%- include('parts/image_field_with_picker', {
                    fieldId: 'image_path',
                    fieldName: 'image_path',
                    label: 'Content afbeelding',
                    value: pageForm.image_path || '',
                    placeholder: '/media/pages/pagina.jpg'
                  }) %>
                  <label for="image_alt" class="form-label">Alt-tekst contentafbeelding</label>
                  <input id="image_alt" name="image_alt" class="form-control" value="<%= pageForm.image_alt || '' %>">
                </div>
                <div class="col-12">
                  <label for="title" class="form-label">Titel</label>
                  <input id="title" name="title" class="form-control" value="<%= pageForm.title || '' %>">
                </div>
                <div class="col-12">
                  <label for="text" class="form-label">Inhoud / SEO tekst</label>
                  <textarea id="text" name="text" class="form-control wysiwyg" rows="10"><%= pageForm.text || '' %></textarea>
                </div>
              </div>
              <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Opslaan</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('parts/media_picker_modal') %>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script src="<%= versionAsset('/js/cms-editor.js') %>"></script>
<script src="<%= versionAsset('/js/seo-meter.js') %>"></script>
<script>
  (function () {
    const templateSelect = document.getElementById('template');
    const aliasInput = document.getElementById('page_alias');
    const bannerWrap = document.getElementById('bannerFieldWrap');
    if (!templateSelect || !aliasInput || !bannerWrap) return;

    function updateBannerVisibility() {
      const isHomeByTemplate = templateSelect.value === 'template-home';
      const isHomeByAlias = (aliasInput.value || '').trim() === '/';
      bannerWrap.style.display = (isHomeByTemplate || isHomeByAlias) ? 'none' : '';
    }

    templateSelect.addEventListener('change', updateBannerVisibility);
    aliasInput.addEventListener('input', updateBannerVisibility);
    updateBannerVisibility();
  })();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
