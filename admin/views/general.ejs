<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('parts/header') %>
</head>

<body>
    <%
    const defaultOpeningDays = ['Maandag', 'Dinsdag', 'Woensdag', 'Donderdag', 'Vrijdag', 'Zaterdag', 'Zondag'];
    let openingHoursRows = [];
    try {
        const parsed = JSON.parse(companyInfo.opening_hours || '[]');
        if (Array.isArray(parsed)) {
            openingHoursRows = parsed
                .map(row => ({
                    day: (row?.day || '').toString().trim(),
                    open: (row?.open || '').toString().trim(),
                    close: (row?.close || '').toString().trim()
                }))
                .filter(row => row.day || row.open || row.close);
        }
    } catch (err) {
        openingHoursRows = (companyInfo.opening_hours || '')
            .toString()
            .split(/\r?\n/)
            .map(line => line.trim())
            .filter(Boolean)
            .map(line => {
                const parts = line.split(':');
                const day = (parts.shift() || '').toString().trim();
                const range = parts.join(':').toString().trim();
                if (!range || /^gesloten$/i.test(range)) {
                    return { day, open: '', close: '' };
                }
                const [open, close] = range.split('-').map(v => (v || '').toString().trim());
                return { day, open, close };
            })
            .filter(row => row.day || row.open || row.close);
    }
	    if (!openingHoursRows.length) {
	        openingHoursRows = defaultOpeningDays.map(day => ({ day, open: '', close: '' }));
	    }
        let externalScriptsRows = [];
        try {
            const parsedExternalScripts = JSON.parse(companyInfo.external_scripts || '[]');
            externalScriptsRows = Array.isArray(parsedExternalScripts)
                ? parsedExternalScripts.map(entry => (entry || '').toString()).filter(entry => entry.trim())
                : [];
        } catch (err) {
            externalScriptsRows = (companyInfo.external_scripts || '')
                .toString()
                .split(/\n\s*\n/)
                .map(block => block.trim())
                .filter(Boolean);
        }
        if (!externalScriptsRows.length) {
            externalScriptsRows = [''];
        }
	    %>
    <main class="d-flex">

        <div class="sidebar">
           <%- include('parts/sidebar', { session: session }) %>
        </div>

        <div class="content general container">

            <h1>Bedrijfsinformatie</h1>

            <% if (saved) { %>
            <div class="alert alert-success">Bedrijfsinformatie succesvol bijgewerkt.</div>
            <% } %>

            <% if (errors && errors.length) { %>
            <div class="alert alert-danger">
                <ul>
                <% errors.forEach(e => { %>
                    <li><%= e.msg %></li>
                <% }) %>
                </ul>
            </div>
            <% } %>

            <form method="post" action="/cms/general" enctype="multipart/form-data" class="needs-validation" novalidate id="companyInfoForm">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="name" class="form-label">Bedrijfsnaam</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= companyInfo.name %>" required>
                    </div>
                    <div class="col-md-6">
                        <%- include('parts/image_field_with_picker', {
                            fieldId: 'logo',
                            fieldName: 'logo',
                            label: 'Logo',
                            value: companyInfo.logo || '',
                            placeholder: '/media/logo/fotohuisvenray.png'
                        }) %>
                    </div>

                    <div class="col-12">
                        <label for="favicon_file" class="form-label">Favicon upload</label>
                        <input type="hidden" name="favicon" value="<%= companyInfo.favicon || '' %>">
                        <input type="file" class="form-control" id="favicon_file" name="favicon_file" accept=".png,.ico,.jpg,.jpeg,.webp,.svg">
                        <div class="form-text">Toegestaan: .png, .ico, .jpg, .jpeg, .webp, .svg. Max 2MB.</div>
                        <% if (companyInfo.favicon) { %>
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <img src="<%= companyInfo.favicon %>" alt="Huidige favicon" style="width:32px;height:32px;object-fit:contain;border:1px solid #ddd;padding:2px;background:#fff;">
                                <small class="text-muted"><%= companyInfo.favicon %></small>
                            </div>
                        <% } %>
                    </div>

                    <div class="col-md-6">
                        <label for="email" class="form-label">Primair e-mailadres</label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= companyInfo.email %>" required>
                    </div>
                    <div class="col-md-6">
                        <label for="mobile" class="form-label">Mobiel</label>
                        <input type="text" class="form-control" id="mobile" name="mobile" value="<%= companyInfo.mobile %>">
                    </div>

                    <div class="col-md-6">
                        <label for="phone" class="form-label">Telefoon</label>
                        <input type="text" class="form-control" id="phone" name="phone" value="<%= companyInfo.phone %>">
                    </div>
                    <div class="col-12 mt-3">
                        <h4 class="mb-1">Adresgegevens</h4>
                    </div>
                    <div class="col-md-8">
                        <label for="address_line_1" class="form-label">Adresregel 1</label>
                        <input type="text" class="form-control" id="address_line_1" name="address_line_1" value="<%= companyInfo.address_line_1 || '' %>">
                    </div>
                    <div class="col-md-4">
                        <label for="address_line_2" class="form-label">Adresregel 2</label>
                        <input type="text" class="form-control" id="address_line_2" name="address_line_2" value="<%= companyInfo.address_line_2 || '' %>">
                    </div>
                    <div class="col-md-3">
                        <label for="postal_code" class="form-label">Postcode</label>
                        <input type="text" class="form-control" id="postal_code" name="postal_code" value="<%= companyInfo.postal_code || '' %>">
                    </div>
                    <div class="col-md-5">
                        <label for="city" class="form-label">Plaats</label>
                        <input type="text" class="form-control" id="city" name="city" value="<%= companyInfo.city || '' %>">
                    </div>
                    <div class="col-md-4">
                        <label for="country" class="form-label">Land</label>
                        <input type="text" class="form-control" id="country" name="country" value="<%= companyInfo.country || '' %>">
                    </div>
                    <div class="col-12">
                        <% const canEditSiteUrl = session?.user?.role === 'admin'; %>
                        <label for="site_url" class="form-label">Website URL</label>
                        <input type="url" class="form-control" id="site_url" name="site_url" value="<%= companyInfo.site_url || '' %>" placeholder="https://www.fotohuisvenray.nl" <%= canEditSiteUrl ? '' : 'disabled' %>>
                        <div class="form-text">
                            Gebruik de volledige URL inclusief `https://`.
                            <%= canEditSiteUrl ? '' : ' Alleen beheerders kunnen dit veld wijzigen.' %>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Openingstijden</label>
                        <div class="table-responsive opening-hours-wrap">
                            <table class="table table-sm align-middle mb-0 opening-hours-table">
                                <thead>
                                    <tr>
                                        <th>Dag</th>
                                        <th>Open</th>
                                        <th>Sluit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% openingHoursRows.forEach((row, idx) => { %>
                                    <tr>
                                        <td>
                                            <input type="text" class="form-control opening-hours-day" name="opening_hours_day[]" value="<%= row.day %>" aria-label="Dag <%= idx + 1 %>" readonly>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control" name="opening_hours_open[]" value="<%= row.open %>" placeholder="09:00" aria-label="Open <%= idx + 1 %>">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control" name="opening_hours_close[]" value="<%= row.close %>" placeholder="18:00" aria-label="Sluit <%= idx + 1 %>">
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <div class="form-text">Laat open/sluit leeg voor gesloten.</div>
                    </div>
                    <div class="col-md-6">
                        <label for="coc" class="form-label">KvK-nummer</label>
                        <input type="text" class="form-control" id="coc" name="coc" value="<%= companyInfo.coc %>">
                    </div>

                    <div class="col-md-6">
                        <label for="instagram" class="form-label">Instagram</label>
                        <input type="url" class="form-control" id="instagram" name="instagram" value="<%= companyInfo.instagram %>">
                    </div>
                    <div class="col-md-6">
                        <label for="facebook" class="form-label">Facebook</label>
                        <input type="url" class="form-control" id="facebook" name="facebook" value="<%= companyInfo.facebook %>">
                    </div>

                    <div class="col-md-6">
                        <label for="linkedin" class="form-label">LinkedIn</label>
                        <input type="url" class="form-control" id="linkedin" name="linkedin" value="<%= companyInfo.linkedin %>">
                    </div>
                    <div class="col-md-6">
                        <label for="tiktok" class="form-label">TikTok</label>
                        <input type="url" class="form-control" id="tiktok" name="tiktok" value="<%= companyInfo.tiktok %>">
                    </div>
                </div>

                <hr class="my-4">
                <h4>Mail / SMTP</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="smtp_host" class="form-label">SMTP host</label>
                        <input type="text" class="form-control" id="smtp_host" name="smtp_host" value="<%= companyInfo.smtp_host || '' %>" placeholder="smtp.hostinger.com">
                    </div>
                    <div class="col-md-3">
                        <label for="smtp_port" class="form-label">SMTP poort</label>
                        <input type="number" class="form-control" id="smtp_port" name="smtp_port" value="<%= companyInfo.smtp_port || '' %>" min="1" max="65535" placeholder="587">
                    </div>
                    <div class="col-md-3">
                        <label for="mail_from" class="form-label">Van-afzender</label>
                        <input type="text" class="form-control" id="mail_from" name="mail_from" value="<%= companyInfo.mail_from || '' %>" placeholder="Website contact <info@domein.nl>">
                    </div>
                    <div class="col-md-6">
                        <label for="smtp_user" class="form-label">SMTP gebruiker</label>
                        <input type="text" class="form-control" id="smtp_user" name="smtp_user" value="<%= companyInfo.smtp_user || '' %>" placeholder="info@domein.nl">
                    </div>
                    <div class="col-md-6">
                        <label for="smtp_pass" class="form-label">SMTP wachtwoord</label>
                        <input type="password" class="form-control" id="smtp_pass" name="smtp_pass" value="<%= companyInfo.smtp_pass || '' %>" placeholder="<%= smtpPassConfigured ? 'Laat leeg om het huidige wachtwoord te behouden' : 'Voer een SMTP wachtwoord in' %>">
                        <div class="form-text">
                            <%= smtpPassConfigured ? 'Er is al een SMTP wachtwoord opgeslagen. Laat dit veld leeg om het bestaande wachtwoord te behouden.' : 'Dit wachtwoord wordt versleuteld opgeslagen in de database.' %>
                        </div>
                    </div>
                </div>

                <hr class="my-4">
                <h4>Media uploads</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="upload_allowed_ext" class="form-label">Toegestane extensies</label>
                        <input type="text" class="form-control" id="upload_allowed_ext" name="upload_allowed_ext" value="<%= companyInfo.upload_allowed_ext || '' %>" placeholder="jpg,jpeg,png,webp,gif,svg">
                        <div class="form-text">Komma-gescheiden lijst zonder punt.</div>
                    </div>
                    <div class="col-md-6">
                        <label for="upload_max_size" class="form-label">Max uploadgrootte</label>
                        <input type="text" class="form-control" id="upload_max_size" name="upload_max_size" value="<%= companyInfo.upload_max_size || '' %>" placeholder="10mb">
                        <div class="form-text">Ondersteunt bijvoorbeeld `5mb`, `10mb` of `500kb`.</div>
                    </div>
                </div>

                <hr class="my-4">
                <h4>Google Tag Manager</h4>
                <div class="row g-3">
                    <div class="col-12">
                        <label for="gtm_head" class="form-label">GTM head-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="gtm_head" name="gtm_head" rows="6"
                            placeholder="Plak hier je GTM head-script"><%= companyInfo.gtm_head || '' %></textarea>
                        </div>
                        <div class="form-text">Script dat binnen de &lt;head&gt;-tag wordt geplaatst.</div>
                    </div>

                    <div class="col-12">
                        <label for="gtm_body" class="form-label">GTM body-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="gtm_body" name="gtm_body" rows="6" placeholder="Plak hier je GTM body-noscript"><%= companyInfo.gtm_body || '' %></textarea>
                        </div>
                        <div class="form-text">Noscript dat direct na de &lt;body&gt;-tag wordt geplaatst.</div>
                    </div>

                    
                    <div class="col-12">
                        <label for="gsc_meta_tag" class="form-label">Google Search Console meta tag</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="gsc_meta_tag" name="gsc_meta_tag" rows="2"
                            placeholder='Plak hier bijvoorbeeld: <meta name="google-site-verification" content="...">'><%= companyInfo.gsc_meta_tag || '' %></textarea>
                        </div>
                        <div class="form-text">Deze meta tag wordt in de &lt;head&gt; geladen. Plak hier de volledige GSC meta tag.</div>
                    </div>

                    <div class="col-12">
                        <label for="cookie" class="form-label">Cookie-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="cookie" name="cookie" rows="1" placeholder="Plak hier je cookie-script"><%= companyInfo.cookie || '' %></textarea>
                        </div>
                    </div>

                    <div class="col-12">
                            <label class="form-label">Extra scripts</label>
                            <div class="border rounded p-3" id="externalScriptsManager">
                                <input type="hidden" name="external_scripts" id="externalScriptsJson" value="<%- JSON.stringify(externalScriptsRows.filter(Boolean)) %>">
                                <div class="d-grid gap-2" id="externalScriptsList">
                                    <% externalScriptsRows.forEach((scriptEntry, index) => { %>
                                    <div class="external-script-row border rounded p-3">
                                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                                            <span class="fw-semibold external-script-label">Script <%= index + 1 %></span>
                                            <button type="button" class="btn btn-outline-danger btn-sm external-script-remove" <%= externalScriptsRows.length === 1 ? 'disabled' : '' %>>Verwijderen</button>
                                        </div>
                                <textarea class="form-control" name="external_scripts_entry[]" rows="5" placeholder="<script src=&quot;https://static.salonized.com/widget.js&quot;><\/script>&#10;of&#10;console.log('Hallo');"><%= scriptEntry %></textarea>
                                    </div>
                                    <% }) %>
                                </div>
                                <button type="button" class="btn btn-outline-secondary mt-3" id="addExternalScriptButton">Script toevoegen</button>
                            </div>
                            <div class="form-text">Voeg hier losse JavaScript-code of complete `<script ...></script>` tags toe. Deze worden tussen WOW.js en de custom scripts geladen.</div>
                    </div>

                    <div class="col-12">
                        <label for="recaptcha_public_key" class="form-label">reCAPTCHA publieke sleutel (V3)</label>
                        <input type="text" class="form-control" id="recaptcha_public_key" name="recaptcha_public_key" value="<%= companyInfo.recaptcha_public_key %>">
                    </div>

                    <div class="col-12">
                        <label for="recaptcha_private_key" class="form-label">reCAPTCHA private sleutel (V3)</label>
                        <input type="text" class="form-control" id="recaptcha_private_key" name="recaptcha_private_key" value="<%= companyInfo.recaptcha_private_key || '' %>">
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-save me-1"></i> Wijzigingen opslaan
                    </button>
                </div>
            </form>


        </div>
    </main>

	    <%- include('parts/media_picker_modal') %>
	        <script>
	            (function () {
                    const form = document.getElementById('companyInfoForm');
	                const list = document.getElementById('externalScriptsList');
	                const addButton = document.getElementById('addExternalScriptButton');
                    const hiddenInput = document.getElementById('externalScriptsJson');
	                if (!form || !list || !addButton || !hiddenInput) return;

                    function syncHiddenInput() {
                        const entries = [...list.querySelectorAll('textarea[name="external_scripts_entry[]"]')]
                            .map((input) => input.value.trim())
                            .filter(Boolean);
                        hiddenInput.value = JSON.stringify(entries);
                    }

	                function updateRemoveButtons() {
	                    const rows = list.querySelectorAll('.external-script-row');
	                    rows.forEach((row, index) => {
	                        const label = row.querySelector('.external-script-label');
	                        const removeButton = row.querySelector('.external-script-remove');
                        if (label) label.textContent = `Script ${index + 1}`;
                        if (removeButton) removeButton.disabled = rows.length === 1;
                    });
                }

                function createRow(value = '') {
                    const row = document.createElement('div');
                    row.className = 'external-script-row border rounded p-3';
                    row.innerHTML = `
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                            <span class="fw-semibold external-script-label">Script</span>
                            <button type="button" class="btn btn-outline-danger btn-sm external-script-remove">Verwijderen</button>
                        </div>
                        <textarea class="form-control" name="external_scripts_entry[]" rows="5" placeholder="<script src=&quot;https://static.salonized.com/widget.js&quot;><\/script>\nof\nconsole.log('Hallo');"></textarea>
                    `;
                    row.querySelector('textarea').value = value;
                    return row;
                }

	                addButton.addEventListener('click', () => {
	                    list.appendChild(createRow(''));
	                    updateRemoveButtons();
                        syncHiddenInput();
	                });

	                list.addEventListener('click', (event) => {
	                    const button = event.target.closest('.external-script-remove');
	                    if (!button) return;

                    const rows = list.querySelectorAll('.external-script-row');
                    if (rows.length === 1) {
                        const input = rows[0].querySelector('textarea');
                        if (input) input.value = '';
                        syncHiddenInput();
                        updateRemoveButtons();
                        return;
                    }

	                    button.closest('.external-script-row')?.remove();
	                    updateRemoveButtons();
                        syncHiddenInput();
	                });

                    list.addEventListener('input', (event) => {
                        if (event.target.matches('textarea[name="external_scripts_entry[]"]')) {
                            syncHiddenInput();
                        }
                    });

                    form.addEventListener('submit', () => {
                        syncHiddenInput();
                    });

	                updateRemoveButtons();
                    syncHiddenInput();
	            })();
	        </script>
	    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
