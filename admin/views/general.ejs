<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('parts/header') %>
</head>

<body>
    <main class="d-flex">

        <div class="sidebar">
           <%- include('parts/sidebar', { session: session }) %>
        </div>

        <div class="content general container">

            <h1>Bedrijfsinformatie</h1>

            <% if (saved) { %>
            <div class="alert alert-success">Bedrijfsinformatie succesvol bijgewerkt.</div>
            <% } %>

            <% if (errors && errors.length) { %>
            <div class="alert alert-danger">
                <ul>
                <% errors.forEach(e => { %>
                    <li><%= e.msg %></li>
                <% }) %>
                </ul>
            </div>
            <% } %>

            <form method="post" action="/cms/general" enctype="multipart/form-data" class="needs-validation" novalidate>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="name" class="form-label">Bedrijfsnaam</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= companyInfo.name %>" required>
                    </div>
                    <div class="col-md-6">
                        <%- include('parts/image_field_with_picker', {
                            fieldId: 'logo',
                            fieldName: 'logo',
                            label: 'Logo',
                            value: companyInfo.logo || '',
                            placeholder: '/media/logo/fotohuisvenray.png'
                        }) %>
                    </div>

                    <div class="col-12">
                        <label for="favicon_file" class="form-label">Favicon upload</label>
                        <input type="hidden" name="favicon" value="<%= companyInfo.favicon || '' %>">
                        <input type="file" class="form-control" id="favicon_file" name="favicon_file" accept=".png,.ico,.jpg,.jpeg,.webp,.svg">
                        <div class="form-text">Toegestaan: .png, .ico, .jpg, .jpeg, .webp, .svg. Max 2MB.</div>
                        <% if (companyInfo.favicon) { %>
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <img src="<%= companyInfo.favicon %>" alt="Huidige favicon" style="width:32px;height:32px;object-fit:contain;border:1px solid #ddd;padding:2px;background:#fff;">
                                <small class="text-muted"><%= companyInfo.favicon %></small>
                            </div>
                        <% } %>
                    </div>

                    <div class="col-md-6">
                        <label for="email" class="form-label">Primair e-mailadres</label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= companyInfo.email %>" required>
                    </div>
                    <div class="col-md-6">
                        <label for="mobile" class="form-label">Mobiel</label>
                        <input type="text" class="form-control" id="mobile" name="mobile" value="<%= companyInfo.mobile %>">
                    </div>

                    <div class="col-md-6">
                        <label for="phone" class="form-label">Telefoon</label>
                        <input type="text" class="form-control" id="phone" name="phone" value="<%= companyInfo.phone %>">
                    </div>
                    <div class="col-12 mt-3">
                        <h4 class="mb-1">Adresgegevens</h4>
                    </div>
                    <div class="col-md-8">
                        <label for="address_line_1" class="form-label">Adresregel 1</label>
                        <input type="text" class="form-control" id="address_line_1" name="address_line_1" value="<%= companyInfo.address_line_1 || '' %>">
                    </div>
                    <div class="col-md-4">
                        <label for="address_line_2" class="form-label">Adresregel 2</label>
                        <input type="text" class="form-control" id="address_line_2" name="address_line_2" value="<%= companyInfo.address_line_2 || '' %>">
                    </div>
                    <div class="col-md-3">
                        <label for="postal_code" class="form-label">Postcode</label>
                        <input type="text" class="form-control" id="postal_code" name="postal_code" value="<%= companyInfo.postal_code || '' %>">
                    </div>
                    <div class="col-md-5">
                        <label for="city" class="form-label">Plaats</label>
                        <input type="text" class="form-control" id="city" name="city" value="<%= companyInfo.city || '' %>">
                    </div>
                    <div class="col-md-4">
                        <label for="country" class="form-label">Land</label>
                        <input type="text" class="form-control" id="country" name="country" value="<%= companyInfo.country || '' %>">
                    </div>
                    <div class="col-md-6">
                        <label for="coc" class="form-label">KvK-nummer</label>
                        <input type="text" class="form-control" id="coc" name="coc" value="<%= companyInfo.coc %>">
                    </div>

                    <div class="col-md-6">
                        <label for="instagram" class="form-label">Instagram</label>
                        <input type="url" class="form-control" id="instagram" name="instagram" value="<%= companyInfo.instagram %>">
                    </div>
                    <div class="col-md-6">
                        <label for="facebook" class="form-label">Facebook</label>
                        <input type="url" class="form-control" id="facebook" name="facebook" value="<%= companyInfo.facebook %>">
                    </div>

                    <div class="col-md-6">
                        <label for="linkedin" class="form-label">LinkedIn</label>
                        <input type="url" class="form-control" id="linkedin" name="linkedin" value="<%= companyInfo.linkedin %>">
                    </div>
                    <div class="col-md-6">
                        <label for="tiktok" class="form-label">TikTok</label>
                        <input type="url" class="form-control" id="tiktok" name="tiktok" value="<%= companyInfo.tiktok %>">
                    </div>
                </div>

                <hr class="my-4">
                <h4>Google Tag Manager</h4>
                <div class="row g-3">
                    <div class="col-12">
                        <label for="gtm_head" class="form-label">GTM head-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="gtm_head" name="gtm_head" rows="6"
                            placeholder="Plak hier je GTM head-script"><%= companyInfo.gtm_head || '' %></textarea>
                        </div>
                        <div class="form-text">Script dat binnen de &lt;head&gt;-tag wordt geplaatst.</div>
                    </div>

                    <div class="col-12">
                        <label for="gtm_body" class="form-label">GTM body-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="gtm_body" name="gtm_body" rows="6" placeholder="Plak hier je GTM body-noscript"><%= companyInfo.gtm_body || '' %></textarea>
                        </div>
                        <div class="form-text">Noscript dat direct na de &lt;body&gt;-tag wordt geplaatst.</div>
                    </div>

                    <div class="col-12">
                        <label for="cookie" class="form-label">Cookie-script</label>
                        <div class="code-block">
                        <textarea class="form-control code-input" id="cookie" name="cookie" rows="1" placeholder="Plak hier je cookie-script"><%= companyInfo.cookie || '' %></textarea>
                        </div>
                    </div>

                    <div class="col-12">
                        <label for="recaptcha_public_key" class="form-label">reCAPTCHA publieke sleutel (V3)</label>
                        <input type="text" class="form-control" id="recaptcha_public_key" name="recaptcha_public_key" value="<%= companyInfo.recaptcha_public_key %>">
                    </div>

                    <div class="col-12">
                        <label for="recaptcha_private_key" class="form-label">reCAPTCHA private sleutel (V3)</label>
                        <input type="text" class="form-control" id="recaptcha_private_key" name="recaptcha_private_key" value="<%= companyInfo.recaptcha_private_key || '' %>">
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-save me-1"></i> Wijzigingen opslaan
                    </button>
                </div>
            </form>


        </div>
    </main>

    <%- include('parts/media_picker_modal') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
