<!DOCTYPE html>
<html lang="nl">
<head>
  <%- include('parts/header') %>
</head>
<body>
<main class="d-flex">
  <div class="sidebar">
    <%- include('parts/sidebar', { session: session }) %>
  </div>

  <div class="content container">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h1 class="mb-0">Impressie</h1>
      <a href="/cms/impression" class="btn btn-outline-secondary">Nieuwe impressie</a>
    </div>

    <% if (saved) { %>
      <div class="alert alert-success">Impressie opgeslagen.</div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach(e => { %>
            <li><%= e.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="card mb-4">
      <div class="card-body">
        <h2 class="h5 mb-3"><%= editing ? 'Impressie bewerken' : 'Impressie toevoegen' %></h2>
        <form method="post" action="<%= editing ? '/cms/impression/update/' + impressionForm.id : '/cms/impression/create' %>">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="name" class="form-label">Naam</label>
              <input id="name" name="name" class="form-control" value="<%= impressionForm.name || '' %>">
            </div>
            <div class="col-md-6">
              <label for="alt" class="form-label">Alt tekst</label>
              <input id="alt" name="alt" class="form-control" value="<%= impressionForm.alt || '' %>">
            </div>
            <div class="col-md-8">
              <%- include('parts/image_field_with_picker', {
                fieldId: 'path',
                fieldName: 'path',
                label: 'Afbeelding pad *',
                value: impressionForm.path || '',
                placeholder: 'impressions/foto.jpg'
              }) %>
            </div>
            <div class="col-md-4">
              <label for="category_id" class="form-label">Categorie *</label>
              <select id="category_id" name="category_id" class="form-select" required>
                <option value="">Kies categorie</option>
                <% categories.forEach(category => { %>
                  <option value="<%= category.id %>" <%= Number(impressionForm.category_id) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <% if (editing) { %>
              <a href="/cms/impression" class="btn btn-outline-secondary">Annuleren</a>
            <% } %>
          </div>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h2 class="h5 mb-3">Bestaande impressies</h2>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Preview</th>
                <th>Naam</th>
                <th>Categorie</th>
                <th class="text-end">Acties</th>
              </tr>
            </thead>
            <tbody>
              <% impressions.forEach(impression => { %>
                <tr>
                  <td style="width:90px;">
                    <% if (impression.path) { %>
                      <img src="<%= impression.path %>" alt="<%= impression.alt || impression.name || '' %>" style="width:70px;height:70px;object-fit:cover;border-radius:6px;">
                    <% } %>
                  </td>
                  <td><%= impression.name || '-' %></td>
                  <td><%= impression.category_name %></td>
                  <td class="text-end">
                    <a href="/cms/impression/<%= impression.id %>" class="btn btn-sm btn-outline-primary">Bewerk</a>
                    <form method="post" action="/cms/impression/delete/<%= impression.id %>" class="d-inline" onsubmit="return confirm('Impressie verwijderen?');">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Verwijder</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (!impressions.length) { %>
                <tr>
                  <td colspan="4" class="text-muted">Nog geen impressies.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('parts/media_picker_modal') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
