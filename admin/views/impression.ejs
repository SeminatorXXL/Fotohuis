<!DOCTYPE html>
<html lang="nl">
<head>
  <%- include('parts/header') %>
</head>
<body>
<style>
  .focus-point-picker {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: repeating-linear-gradient(45deg, #f3f5f7, #f3f5f7 14px, #e9edf1 14px, #e9edf1 28px);
    cursor: crosshair;
  }

  .focus-point-picker img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .focus-point-picker[hidden] {
    display: none !important;
  }

  .focus-point-marker {
    position: absolute;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: rgba(13, 110, 253, 0.95);
    box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.2);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .focus-point-marker::before,
  .focus-point-marker::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    background: #fff;
    transform: translate(-50%, -50%);
  }

  .focus-point-marker::before {
    width: 2px;
    height: 28px;
  }

  .focus-point-marker::after {
    width: 28px;
    height: 2px;
  }
</style>
<main class="d-flex">
  <div class="sidebar">
    <%- include('parts/sidebar', { session: session }) %>
  </div>

  <div class="content container">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
      <h1 class="mb-0">Impressie</h1>
      <a href="/cms/impression" class="btn btn-outline-secondary">Nieuwe impressie</a>
    </div>

    <% if (saved) { %>
      <div class="alert alert-success">Impressie opgeslagen.</div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach(e => { %>
            <li><%= e.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="card mb-4">
      <div class="card-body">
        <h2 class="h5 mb-3"><%= editing ? 'Impressie bewerken' : 'Impressie toevoegen' %></h2>
        <form method="post" action="<%= editing ? '/cms/impression/update/' + impressionForm.id : '/cms/impression/create' %>">
          <input type="hidden" name="selected_category_id" value="<%= selectedCategoryId || '' %>">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="name" class="form-label">Naam</label>
              <input id="name" name="name" class="form-control" value="<%= impressionForm.name || '' %>">
            </div>
            <div class="col-md-6">
              <label for="alt" class="form-label">Alt tekst</label>
              <input id="alt" name="alt" class="form-control" value="<%= impressionForm.alt || '' %>">
            </div>
            <div class="col-md-8">
              <%- include('parts/image_field_with_picker', {
                fieldId: 'path',
                fieldName: 'path',
                label: 'Afbeelding pad *',
                value: impressionForm.path || '',
                placeholder: 'impressions/foto.jpg'
              }) %>
            </div>
            <div class="col-md-4">
              <label for="category_id" class="form-label">Categorie *</label>
              <select id="category_id" name="category_id" class="form-select" required>
                <option value="">Kies categorie</option>
                <% categories.forEach(category => { %>
                  <option value="<%= category.id %>" <%= Number(impressionForm.category_id) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">Focuspunt homepage slider</label>
              <div id="focusPointPicker" class="focus-point-picker" role="button" tabindex="0" aria-label="Klik op de preview om het focuspunt voor de homepage slider te kiezen">
                <img id="focusPointPreview" alt="Preview focuspunt impressie">
                <span id="focusPointMarker" class="focus-point-marker" aria-hidden="true"></span>
              </div>
              <div class="form-text">Klik op de preview om te bepalen welk deel van de foto in de homepage slider centraal blijft. Handig bij verticale of sterk uitgesneden beelden.</div>
            </div>
            <div class="col-md-3">
              <label for="focus_x" class="form-label">Focus X (%)</label>
              <input id="focus_x" name="focus_x" class="form-control" type="number" min="0" max="100" step="0.1" value="<%= impressionForm.focus_x ?? 50 %>">
            </div>
            <div class="col-md-3">
              <label for="focus_y" class="form-label">Focus Y (%)</label>
              <input id="focus_y" name="focus_y" class="form-control" type="number" min="0" max="100" step="0.1" value="<%= impressionForm.focus_y ?? 50 %>">
            </div>
            <div class="col-md-6 d-flex align-items-end">
              <button type="button" class="btn btn-outline-secondary" id="focusPointReset">Reset naar midden</button>
            </div>
            <div class="col-12">
              <div class="form-check">
                <input id="exclude_from_homepage" name="exclude_from_homepage" class="form-check-input" type="checkbox" value="1" <%= Number(impressionForm.exclude_from_homepage) === 1 ? 'checked' : '' %>>
                <label for="exclude_from_homepage" class="form-check-label">Uitsluiten van homepage</label>
              </div>
            </div>
          </div>
          <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <% if (editing) { %>
              <a href="/cms/impression<%= selectedCategoryId ? '?category_id=' + selectedCategoryId : '' %>" class="btn btn-outline-secondary">Annuleren</a>
            <% } %>
          </div>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
          <h2 class="h5 mb-0">Bestaande impressies</h2>
          <form method="get" action="/cms/impression" class="d-flex gap-2 align-items-center flex-nowrap">
            <label for="filter_category_id" class="form-label mb-0 text-nowrap">Filter categorie</label>
            <select id="filter_category_id" name="category_id" class="form-select">
              <option value="">Alle categorieen</option>
              <% categories.forEach(category => { %>
                <option value="<%= category.id %>" <%= Number(selectedCategoryId) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
              <% }) %>
            </select>
            <% if (selectedCategoryId) { %>
              <a href="/cms/impression" class="btn btn-outline-light border">Reset</a>
            <% } %>
          </form>
        </div>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Preview</th>
                <th>Naam</th>
                <th>Categorie</th>
                <th>Homepage</th>
                <th>Focus</th>
                <th class="text-end">Acties</th>
              </tr>
            </thead>
            <tbody>
              <% impressions.forEach(impression => { %>
                <tr>
                  <td style="width:90px;">
                    <% if (impression.path) { %>
                      <img src="<%= impression.path %>" alt="<%= impression.alt || impression.name || '' %>" style="width:70px;height:70px;object-fit:cover;object-position:<%= Number(impression.focus_x ?? 50) %>% <%= Number(impression.focus_y ?? 50) %>%;border-radius:6px;">
                    <% } %>
                  </td>
                  <td><%= impression.name || '-' %></td>
                  <td><%= impression.category_name %></td>
                  <td><%= Number(impression.exclude_from_homepage) === 1 ? 'Verborgen' : 'Zichtbaar' %></td>
                  <td><%= Number(impression.focus_x ?? 50) %>% / <%= Number(impression.focus_y ?? 50) %>%</td>
                  <td class="text-end">
                    <a href="/cms/impression/<%= impression.id %><%= selectedCategoryId ? '?category_id=' + selectedCategoryId : '' %>" class="btn btn-sm btn-outline-primary">Bewerk</a>
                    <form method="post" action="/cms/impression/delete/<%= impression.id %>" class="d-inline" onsubmit="return confirm('Impressie verwijderen?');">
                      <input type="hidden" name="selected_category_id" value="<%= selectedCategoryId || '' %>">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Verwijder</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (!impressions.length) { %>
                <tr>
                  <td colspan="6" class="text-muted">Nog geen impressies.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('parts/media_picker_modal') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  (() => {
    const categoryFilter = document.getElementById('filter_category_id');
    if (!categoryFilter || !categoryFilter.form) return;
    categoryFilter.addEventListener('change', () => {
      categoryFilter.form.submit();
    });
  })();

  (() => {
    const pathInput = document.getElementById('path');
    const focusXInput = document.getElementById('focus_x');
    const focusYInput = document.getElementById('focus_y');
    const picker = document.getElementById('focusPointPicker');
    const preview = document.getElementById('focusPointPreview');
    const marker = document.getElementById('focusPointMarker');
    const resetButton = document.getElementById('focusPointReset');

    if (!pathInput || !focusXInput || !focusYInput || !picker || !preview || !marker || !resetButton) {
      return;
    }

    function buildSrc(val, base) {
      if (!val) return '';
      const v = String(val).trim().replace(/\\/g, '/');
      if (/^https?:\/\//i.test(v)) return v;
      if (v.startsWith('/')) return v;
      if (v.startsWith('media/')) return '/' + v;
      if (v.includes('/')) return '/media/' + v.replace(/^\/+/, '');
      return '/media' + (base ? '/' + base : '') + '/' + v;
    }

    function clampPercent(value) {
      const parsed = Number.parseFloat(String(value ?? '').replace(',', '.'));
      if (!Number.isFinite(parsed)) return 50;
      return Math.min(100, Math.max(0, parsed));
    }

    function syncPreviewSource() {
      const src = buildSrc(pathInput.value, (pathInput.dataset.previewBase || '').replace(/^\/|\/$/g, ''));
      const hasImage = Boolean(src);

      picker.hidden = !hasImage;

      if (hasImage) {
        preview.src = src;
      } else {
        preview.removeAttribute('src');
      }
    }

    function syncMarker() {
      const x = clampPercent(focusXInput.value);
      const y = clampPercent(focusYInput.value);

      focusXInput.value = x % 1 === 0 ? String(x) : x.toFixed(1);
      focusYInput.value = y % 1 === 0 ? String(y) : y.toFixed(1);
      marker.style.left = `${x}%`;
      marker.style.top = `${y}%`;
      preview.style.objectPosition = `${x}% ${y}%`;
    }

    function setFocusFromPointer(clientX, clientY) {
      const rect = picker.getBoundingClientRect();
      if (!rect.width || !rect.height) return;

      const x = ((clientX - rect.left) / rect.width) * 100;
      const y = ((clientY - rect.top) / rect.height) * 100;

      focusXInput.value = clampPercent(x).toFixed(1);
      focusYInput.value = clampPercent(y).toFixed(1);
      syncMarker();
    }

    picker.addEventListener('click', (event) => {
      setFocusFromPointer(event.clientX, event.clientY);
    });

    picker.addEventListener('keydown', (event) => {
      const step = event.shiftKey ? 10 : 2;
      let handled = true;
      const currentX = clampPercent(focusXInput.value);
      const currentY = clampPercent(focusYInput.value);

      if (event.key === 'ArrowLeft') focusXInput.value = currentX - step;
      else if (event.key === 'ArrowRight') focusXInput.value = currentX + step;
      else if (event.key === 'ArrowUp') focusYInput.value = currentY - step;
      else if (event.key === 'ArrowDown') focusYInput.value = currentY + step;
      else handled = false;

      if (!handled) return;

      event.preventDefault();
      syncMarker();
    });

    focusXInput.addEventListener('input', syncMarker);
    focusYInput.addEventListener('input', syncMarker);
    pathInput.addEventListener('input', syncPreviewSource);
    pathInput.addEventListener('change', syncPreviewSource);

    resetButton.addEventListener('click', () => {
      focusXInput.value = '50';
      focusYInput.value = '50';
      syncMarker();
    });

    syncPreviewSource();
    syncMarker();
  })();
</script>
</body>
</html>
